{
  "name": "json-schema-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p validate:themes type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "validate:themes": "node scripts/validate-themes.mjs",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "lint:check": "run-s lint:check:*",
    "lint:check:oxlint": "oxlint . -D correctness --ignore-path .gitignore",
    "lint:check:eslint": "eslint .",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@kong/spec-renderer": "^1.107.15",
    "@visual-json/core": "^0.3.1",
    "@visual-json/vue": "^0.3.1",
    "@vueuse/core": "^14.3.0",
    "lz-string": "^1.5.0",
    "shiki": "^3.23.0",
    "splitpanes": "^4.0.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.106",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.18",
    "@types/splitpanes": "^2.2.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "~1.1.0",
    "eslint-plugin-vue": "~10.2.0",
    "jiti": "^2.7.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.1.0",
    "prettier": "3.5.3",
    "typescript": "~5.8.3",
    "unplugin-fonts": "^1.4.0",
    "unplugin-icons": "^23.0.1",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vue-tsc": "^2.2.12"
  }
}
